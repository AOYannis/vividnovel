# Copy to .env and fill in your values for local dev.
# On Railway/production, set these in the frontend service variables.

# ── Supabase (public client config) ──
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your-anon-key

# ── Backend URL ──
# Leave EMPTY in dev (Vite proxy handles /api → localhost:8001)
# Set to backend Railway URL in prod (e.g. https://backend-xxx.up.railway.app)
VITE_API_BASE=
