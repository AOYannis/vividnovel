# Copy to .env and fill in your actual keys for local dev.
# On Railway/production, set these as environment variables in the dashboard.

# ── Supabase (auth + DB) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
ADMIN_USER_IDS=comma,separated,supabase,user,uuids

# ── Image generation ──
RUNWARE_API_KEY=your-runware-api-key
WAVESPEEDAI_API_KEY=your-wavespeed-api-key  # optional
FAL_API_KEY=your-fal-api-key  # optional

# ── LLM (Grok via xAI) ──
XAI_API_KEY=xai-your-key

# ── Video generation ──
runpod_Pruna_API=rpa_your-runpod-key  # for Pruna P-Video on RunPod
DAVINCI_POD_ID=your-davinci-pod-id  # optional, for MagiHuman talking-head
DAVINCI_API_KEY=your-davinci-api-key  # optional

# ── Memory (Mem0) ──
MEM0_API_KEY=m0-your-mem0-key  # optional
